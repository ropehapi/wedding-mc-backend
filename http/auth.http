### Variáveis globais
@baseUrl = http://localhost:8080
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkYWYzZTNhZS1iM2M2LTRiZTYtOGVlYy0wNTAzNTNkNzRiODUiLCJleHAiOjE3NzYyMjA5NjYsImlhdCI6MTc3NjIxNzM2Nn0.V6okMSFWHVbksUJ72lnU5orXLUJZ9BN4JPeHvXAFlBw


### 1. Registrar casal
# Cria uma nova conta. Retorna o usuário criado (201).
# Rode isso primeiro para criar sua conta.
POST {{baseUrl}}/v1/auth/register
Content-Type: application/json

{
  "name": "Ana e João",
  "email": "ana@email.com",
  "password": "senha123"
}


### 2. Login
# Autentica e retorna access_token + refresh_token.
# Copie o access_token e cole na variável @token acima.
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "email": "ana@email.com",
  "password": "senha123"
}


### 3. Renovar access token
# Use o refresh_token retornado no login quando o access_token expirar.
POST {{baseUrl}}/v1/auth/refresh
Content-Type: application/json

{
  "refresh_token": "UBdR3bzl-VYpIYde_l_wciL_a9muAiiH9X4dKDYX3to"
}


### 4. Logout
# Invalida todos os refresh tokens do usuário autenticado.
POST {{baseUrl}}/v1/auth/logout
Authorization: Bearer {{token}}


### 5. Solicitar recuperação de senha
# Gera um token de reset e o exibe no log do servidor (mailer de log).
# Em produção, o link seria enviado por e-mail.
POST {{baseUrl}}/v1/auth/forgot-password
Content-Type: application/json

{
  "email": "ana@email.com"
}


### 6. Redefinir senha com token
# Cole o token exibido no log do servidor no campo "token".
# Após o uso, o token fica inválido e todas as sessões são revogadas.
POST {{baseUrl}}/v1/auth/reset-password
Content-Type: application/json

{
  "token": "COLE_O_TOKEN_AQUI",
  "new_password": "novaSenha123"
}


### 7. Alterar senha (autenticado)
# Requer o JWT válido. Verifica a senha atual antes de alterar.
POST {{baseUrl}}/v1/auth/change-password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "current_password": "senha123",
  "new_password": "novaSenha123"
}


### --- Cenários de erro ---

### Registro com e-mail duplicado → 409
POST {{baseUrl}}/v1/auth/register
Content-Type: application/json

{
  "name": "Outro",
  "email": "ana@email.com",
  "password": "senha123"
}


### Registro com senha fraca → 422
POST {{baseUrl}}/v1/auth/register
Content-Type: application/json

{
  "name": "Teste",
  "email": "fraca@email.com",
  "password": "123"
}


### Login com senha errada → 401
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "email": "ana@email.com",
  "password": "errada"
}
